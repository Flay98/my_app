= form_with(model: image) do |form|
  - if image.errors.any?
    %div{style: "color: red"}
      %h2= "#{pluralize(image.errors.count, "error")} prohibited this image from being saved:"

      %ul
        - image.errors.each do |error|
          %li= error.full_message

  %div
    = form.label :task_id, style: "display: block"
    = form.text_field :task_id

  %div
    = form.label :file_name, style: "display: block"
    = form.text_field :file_name

  %div
    = form.label :description, style: "display: block"
    = form.text_area :description

  %div
    = form.submit
