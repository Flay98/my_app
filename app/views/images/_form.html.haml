= form_with(model: image) do |form|
  - if image.errors.any?
    %div{style: "color: red"}
      %h2= "#{pluralize(image.errors.count, "error")} prohibited this image from being saved:"

      %ul
        - image.errors.each do |error|
          %li= error.full_message

  %div
    = form.label :task_id, t(".task"), style: "display: block"
    = form.collection_select :task_id, Task.all, :id, :title, prompt: true

  %div
    = form.label :photo, "Загрузить изображение", style: "display: block"
    = form.file_field :photo

  %div
    = form.label :file_name, t(".file_name"), style: "display: block"
    = form.text_field :file_name

  %div
    = form.label :description, t(".description"), style: "display: block"
    = form.text_area :description

  %div
    = form.submit t(".submit")
