%p{style: "color: green"}= notice

.image-show-page
  %h1= t("images.show.title", default: "Изображение")

  .image-show-card
    .image-show-card__preview
      - image_src = image_source_for(@image)
      - if image_src.present?
        = image_tag image_src, class: "image-show-card__image"
      - else
        .image-show-card__placeholder
          = t("images.index.no_file")

    .image-show-card__content
      %p
        %strong= "#{t('images.index.description', default: 'Описание')}:"
        = @image.description.presence || t("images.index.no_description", default: "Без описания")

      %p
        %strong= "#{t('images.index.task', default: 'Задача')}:"
        = @image.task&.title || "—"

      %p
        %strong= "#{t('images.index.theme', default: 'Тема')}:"
        = @image.task&.theme&.name || "—"

      %p
        %strong= "#{t('images.index.avg_rating', default: 'Средняя оценка')}:"
        = @image.average_rating_text

  .image-show-actions
    = link_to edit_image_path(@image), class: "image-show-button image-show-button--primary" do
      = t("images.show.edit", default: "Редактировать")

    = link_to images_path, class: "image-show-button image-show-button--secondary" do
      = t("images.show.back", default: "Назад к изображениям")