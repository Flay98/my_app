.profile-page
  .profile-hero
    .profile-hero__avatar
      = avatar_for @user, size: 120

    .profile-hero__content
      %p.profile-hero__label= t("users.show.profile_label")
      %h1= @user.username
      %p.profile-hero__email= @user.email
      %p.profile-hero__role
        = @user.role

      .profile-hero__actions
        = link_to t("users.show.proceed_to_work"), work_path, class: "profile-button profile-button--primary"
        = link_to t("users.show.back_to_images"), images_path, class: "profile-button profile-button--secondary"
        - if signed_in? && (current_user == @user || current_user.admin?)
          = link_to t("users.show.edit_profile"), edit_user_path(@user), class: "profile-button profile-button--secondary"

  .profile-stats
    .profile-stat-card
      %span.profile-stat-card__value= @ratings_count
      %span.profile-stat-card__label= t("users.show.ratings_count")

    .profile-stat-card
      %span.profile-stat-card__value= @average_given_rating || t("users.show.no_ratings")
      %span.profile-stat-card__label= t("users.show.average_given_rating")

    .profile-stat-card
      %span.profile-stat-card__value= @user.created_at.strftime("%d.%m.%Y")
      %span.profile-stat-card__label= t("users.show.member_since")

  .profile-section
    .profile-section__header
      %h2= t("users.show.recent_ratings")

    - if @recent_ratings.any?
      .profile-ratings-list
        - @recent_ratings.each do |rating|
          .profile-rating-item
            .profile-rating-item__preview
              - image = rating.image
                - image_src = image_source_for(image)
                - if image_src.present?
                  = image_tag image_src, class: "profile-rating-item__image"
                - else
                  .profile-rating-item__placeholder= t("users.show.no_image")

            .profile-rating-item__content
              %h3= rating.image.description.presence || t("users.show.no_description")
              %p
                %span= "#{t('users.show.theme')}:"
                = rating.image.task&.theme&.name || "—"
              %p
                %span= "#{t('users.show.task')}:"
                = rating.image.task&.title || "—"

            .profile-rating-item__score
              = rating.rating
    - else
      .profile-empty
        %p= t("users.show.no_recent_ratings")