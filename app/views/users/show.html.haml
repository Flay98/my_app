%p{style: "color: green"}= notice

.show_user
  %h1
    = gravatar_for @user
    = @user.username

  %p
    %strong Email:
    = @user.email

  %p
    %strong First name:
    = @user.first_name

  %p
    %strong Last name:
    = @user.last_name

  = link_to "Proceed to work!", work_path, class: "btn btn-lg btn-primary"

%div
  = link_to "Edit this user", edit_user_path(@user)
  |
  = link_to "Back to users", users_path

  = button_to "Destroy this user", @user, method: :delete
