.auth-page
  .auth-card.auth-card--wide
    .auth-card__header
      .auth-card__mark TT
      %h1= t("users.new.title")
      %p= t("users.new.subtitle")

    = form_with(model: user, class: "auth-form") do |form|
      - if user.errors.any?
        .auth-errors
          %h2= t("users.form.errors_title")
          %ul
            - user.errors.each do |error|
              %li= error.full_message

      .auth-form__grid
        .auth-form__field
          = form.label :username, t("users.form.username")
          = form.text_field :username, class: "auth-form__input", placeholder: "designer01"

        .auth-form__field
          = form.label :email, t("users.form.email")
          = form.email_field :email, class: "auth-form__input", placeholder: "example@mail.com"

        .auth-form__field
          = form.label :first_name, t("users.form.first_name")
          = form.text_field :first_name, class: "auth-form__input", placeholder: t("users.form.first_name")

        .auth-form__field
          = form.label :last_name, t("users.form.last_name")
          = form.text_field :last_name, class: "auth-form__input", placeholder: t("users.form.last_name")

        .auth-form__field
          = form.label :password, t("users.form.password")
          = form.password_field :password, class: "auth-form__input", placeholder: "••••••••"

        .auth-form__field
          = form.label :password_confirmation, t("users.form.password_confirmation")
          = form.password_field :password_confirmation, class: "auth-form__input", placeholder: "••••••••"

        .auth-form__field
          = form.label :avatar, t("users.form.avatar")
          = form.file_field :avatar, class: "auth-form__input"

      .auth-form__actions
        = form.submit t("users.form.create_account"), class: "auth-form__submit"

    .auth-card__footer
      %span= t("users.new.have_account")
      = link_to t("users.new.sign_in"), signin_path