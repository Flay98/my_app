.main-dashboard
  .main-hero
    .main-hero__card
      %span.main-hero__label Task Tracker
      %h1= t(".title")
      %p= t(".description")

      - if signed_in?
        = link_to t(".proceed_to_work"), work_path, class: "main-hero__button"
      - else
        = link_to t(".sign_up_now"), signup_path, class: "main-hero__button"

  .dashboard-stats
    .dashboard-stat-card
      %span.dashboard-stat-card__value= @images_count
      %span.dashboard-stat-card__label= t(".images_count")

    .dashboard-stat-card
      %span.dashboard-stat-card__value= @users_count
      %span.dashboard-stat-card__label= t(".users_count")

    .dashboard-stat-card
      %span.dashboard-stat-card__value= @ratings_count
      %span.dashboard-stat-card__label= t(".ratings_count")

    .dashboard-stat-card
      %span.dashboard-stat-card__value= @system_average_rating || t(".no_ratings")
      %span.dashboard-stat-card__label= t(".average_rating")

  .dashboard-section
    .dashboard-section__header
      %h2= t(".top_images")
      = link_to t(".open_gallery"), images_path

    - if @top_images.any?
      .dashboard-top-grid
        - @top_images.each do |image|
          .dashboard-top-card
            .dashboard-top-card__preview
              - image_src = image_source_for(image)
              - if image_src.present?
                = image_tag image_src, class: "dashboard-top-card__image"
              - else
                .dashboard-top-card__placeholder= t(".no_image")

            .dashboard-top-card__body
              %h3= image.description.presence || t(".no_description")
              %p= image.task&.theme&.name || "—"
              %span.dashboard-top-card__rating
                = "#{t('.rating')}: #{image.average_rating_text}"
    - else
      .dashboard-empty
        %p= t(".no_top_images")
